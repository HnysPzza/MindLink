<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:M1ndLink.Views"
       x:Class="M1ndLink.AppShell"
       Shell.NavBarIsVisible="False"
       Shell.TabBarBackgroundColor="White"
       Shell.TabBarForegroundColor="#2563EB"
       Shell.TabBarUnselectedColor="#93C5FD"
       Shell.TabBarTitleColor="#2563EB">

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="icon_home.svg"
            Route="Home"
            ContentTemplate="{DataTemplate views:HomePage}"/>

        <ShellContent
            Title="Assessment"
            Icon="icon_assessment.svg"
            Route="Assessment"
            ContentTemplate="{DataTemplate views:AssessmentPage}"/>

        <ShellContent
            Title="Exercises"
            Icon="icon_exercises.svg"
            Route="Exercises"
            ContentTemplate="{DataTemplate views:ExercisesPage}"/>

        <ShellContent
            Title="Profile"
            Icon="icon_profile.svg"
            Route="Profile"
            ContentTemplate="{DataTemplate views:ProfilePage}"/>
    </TabBar>
</Shell>
