<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:M1ndLink.ViewModels"
             x:Class="M1ndLink.Views.VerifyOtpPage"
             Title="Verify Email"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E8F1FB" Offset="0.0"/>
            <GradientStop Color="#F0F8FF" Offset="0.5"/>
            <GradientStop Color="#D6EAF8" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <!-- Background Blobs -->
        <AbsoluteLayout>
            <Ellipse Fill="#224A90D9" WidthRequest="220" HeightRequest="220"
                     AbsoluteLayout.LayoutBounds="-60, -60, 220, 220"/>
            <Ellipse Fill="#1A6BB8C4" WidthRequest="260" HeightRequest="260"
                     AbsoluteLayout.LayoutBounds="1, 1, 260, 260"
                     AbsoluteLayout.LayoutFlags="PositionProportional"/>
        </AbsoluteLayout>

        <!-- Main Content -->
        <ScrollView>
            <VerticalStackLayout Padding="32" VerticalOptions="Center" Spacing="0">

                <BoxView HeightRequest="40" Color="Transparent"/>

                <!-- Envelope Icon Circle -->
                <Border x:Name="IconBorder"
                        WidthRequest="80" HeightRequest="80"
                        StrokeShape="RoundRectangle 40"
                        BackgroundColor="{StaticResource SoftTeal}"
                        Stroke="Transparent"
                        HorizontalOptions="Center">
                    <Label Text="✉"
                           FontSize="34"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <BoxView HeightRequest="24" Color="Transparent"/>

                <!-- Heading -->
                <Label x:Name="TitleLabel"
                       Text="Check your email"
                       Style="{StaticResource DisplayHeading}"
                       HorizontalOptions="Center"/>

                <!-- Subtitle -->
                <Label x:Name="SubtitleLabel"
                       Text="We sent a 6-digit code to"
                       TextColor="{StaticResource TextMuted}"
                       FontFamily="Lato"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,6,0,0"/>

                <Label x:Name="EmailLabel"
                       Text="{Binding Email}"
                       TextColor="{StaticResource DeepBlue}"
                       FontFamily="LatoSemiBold"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,2,0,0"/>

                <BoxView HeightRequest="32" Color="Transparent"/>

                <!-- 6 OTP Digit Boxes -->
                <HorizontalStackLayout x:Name="OtpRow" HorizontalOptions="Center" Spacing="10">

                    <Border x:Name="OtpBox1" WidthRequest="48" HeightRequest="58"
                            StrokeShape="RoundRectangle 12" Stroke="#D0E4F5"
                            StrokeThickness="1.5" BackgroundColor="White">
                        <Entry x:Name="OtpEntry1" ClassId="1" MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center" FontSize="22"
                               FontFamily="NunitoBold" TextColor="{StaticResource TextDark}"
                               BackgroundColor="Transparent"
                               TextChanged="OnOtpDigitChanged"/>
                    </Border>

                    <Border x:Name="OtpBox2" WidthRequest="48" HeightRequest="58"
                            StrokeShape="RoundRectangle 12" Stroke="#D0E4F5"
                            StrokeThickness="1.5" BackgroundColor="White">
                        <Entry x:Name="OtpEntry2" ClassId="2" MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center" FontSize="22"
                               FontFamily="NunitoBold" TextColor="{StaticResource TextDark}"
                               BackgroundColor="Transparent"
                               TextChanged="OnOtpDigitChanged"/>
                    </Border>

                    <Border x:Name="OtpBox3" WidthRequest="48" HeightRequest="58"
                            StrokeShape="RoundRectangle 12" Stroke="#D0E4F5"
                            StrokeThickness="1.5" BackgroundColor="White">
                        <Entry x:Name="OtpEntry3" ClassId="3" MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center" FontSize="22"
                               FontFamily="NunitoBold" TextColor="{StaticResource TextDark}"
                               BackgroundColor="Transparent"
                               TextChanged="OnOtpDigitChanged"/>
                    </Border>

                    <Border x:Name="OtpBox4" WidthRequest="48" HeightRequest="58"
                            StrokeShape="RoundRectangle 12" Stroke="#D0E4F5"
                            StrokeThickness="1.5" BackgroundColor="White">
                        <Entry x:Name="OtpEntry4" ClassId="4" MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center" FontSize="22"
                               FontFamily="NunitoBold" TextColor="{StaticResource TextDark}"
                               BackgroundColor="Transparent"
                               TextChanged="OnOtpDigitChanged"/>
                    </Border>

                    <Border x:Name="OtpBox5" WidthRequest="48" HeightRequest="58"
                            StrokeShape="RoundRectangle 12" Stroke="#D0E4F5"
                            StrokeThickness="1.5" BackgroundColor="White">
                        <Entry x:Name="OtpEntry5" ClassId="5" MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center" FontSize="22"
                               FontFamily="NunitoBold" TextColor="{StaticResource TextDark}"
                               BackgroundColor="Transparent"
                               TextChanged="OnOtpDigitChanged"/>
                    </Border>

                    <Border x:Name="OtpBox6" WidthRequest="48" HeightRequest="58"
                            StrokeShape="RoundRectangle 12" Stroke="#D0E4F5"
                            StrokeThickness="1.5" BackgroundColor="White">
                        <Entry x:Name="OtpEntry6" ClassId="6" MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center" FontSize="22"
                               FontFamily="NunitoBold" TextColor="{StaticResource TextDark}"
                               BackgroundColor="Transparent"
                               TextChanged="OnOtpDigitChanged"/>
                    </Border>

                </HorizontalStackLayout>

                <!-- Error Label -->
                <Label x:Name="ErrorLabel"
                       Text="Invalid code. Please try again."
                       TextColor="{StaticResource ErrorRed}"
                       FontFamily="LatoSemiBold"
                       FontSize="12"
                       HorizontalOptions="Center"
                       IsVisible="False"
                       Margin="0,10,0,0"/>

                <BoxView HeightRequest="28" Color="Transparent"/>

                <!-- Verify Button -->
                <Button x:Name="VerifyButton"
                        Text="Verify Email"
                        BackgroundColor="{StaticResource PrimaryBlue}"
                        TextColor="White"
                        FontFamily="NunitoSemiBold"
                        FontSize="16"
                        CornerRadius="14"
                        HeightRequest="52"
                        IsEnabled="False"
                        Opacity="0.6"
                        Clicked="OnVerifyClicked"
                        Shadow="{Shadow Brush='#404A90D9', Offset='0,4', Radius=12}"/>

                <BoxView HeightRequest="20" Color="Transparent"/>

                <!-- Resend Row -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Didn't receive a code?" TextColor="{StaticResource TextMuted}"
                           FontFamily="Lato" FontSize="13" VerticalOptions="Center"/>
                    <Label x:Name="ResendLabel" Text="Resend"
                           TextColor="{StaticResource PrimaryBlue}"
                           FontFamily="NunitoSemiBold" FontSize="13" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnResendTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <BoxView HeightRequest="12" Color="Transparent"/>

                <!-- Return to Sign In -->
                <Label Text="Return to Sign In"
                       TextColor="{StaticResource TextMuted}"
                       FontFamily="Lato"
                       FontSize="13"
                       HorizontalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
