<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:M1ndLink.Controls"
             xmlns:models="clr-namespace:M1ndLink.Models"
             xmlns:vm="clr-namespace:M1ndLink.ViewModels"
             x:Class="M1ndLink.Views.NotificationsPage"
             x:DataType="vm:NotificationsViewModel">

    <Grid>
        <controls:GradientBackgroundView InputTransparent="True" ZIndex="0"/>

        <Grid ZIndex="1" RowDefinitions="Auto,*">

            <!-- ── Sticky Header ── -->
            <Border Grid.Row="0"
                    StrokeThickness="0"
                    Padding="20,52,20,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#EAEFF6FF" Offset="0"/>
                        <GradientStop Color="#00EFF6FF"  Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Back -->
                    <Label Grid.Column="0"
                           Text="←" FontSize="22"
                           TextColor="{StaticResource AccentPrimary}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Grid.Column="1"
                           Text="Notifications"
                           Style="{StaticResource DisplayHeading}"
                           HorizontalOptions="Center"/>

                    <!-- Clear All -->
                    <Label Grid.Column="2"
                           Text="Clear All"
                           FontFamily="DMSansMedium" FontSize="13"
                           TextColor="{StaticResource AccentPrimary}"
                           VerticalOptions="Center"
                           IsVisible="{Binding IsEmpty,
                               Converter={StaticResource InverseBoolConverter}}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearAllCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <!-- ── List or Empty State ── -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20,0,20,40" Spacing="0">

                    <!-- Empty state -->
                    <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="12"
                                         Margin="0,60,0,0">
                        <Label Text="🔔" FontSize="56" HorizontalOptions="Center"/>
                        <Label Text="No Notifications Yet"
                               Style="{StaticResource SectionHeading}"
                               HorizontalOptions="Center"/>
                        <Label Text="Activity from mood logs, assessments,&#10;exercises and profile changes will appear here."
                               Style="{StaticResource BodyText}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- Notification list -->
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Items}"
                        IsVisible="{Binding IsEmpty,
                            Converter={StaticResource InverseBoolConverter}}"
                        Spacing="0">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:AppNotification">
                                <Grid Margin="0,0,0,12">
                                    <!-- Notification Card -->
                                    <Border StrokeShape="RoundRectangle 18"
                                            Stroke="{StaticResource CardBorderColor}"
                                            StrokeThickness="1"
                                            Padding="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                                <GradientStop Color="#B3FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Shadow>
                                            <Shadow Brush="#2563EB" Offset="0,3" Radius="14" Opacity="0.07"/>
                                        </Border.Shadow>

                                        <Grid ColumnDefinitions="5,Auto,*,Auto" Padding="0,14,14,14">

                                            <!-- Category accent bar -->
                                            <BoxView Grid.Column="0"
                                                     BackgroundColor="{Binding CategoryColor}"
                                                     CornerRadius="0,3,3,0"/>

                                            <!-- Icon badge -->
                                            <Border Grid.Column="1"
                                                    WidthRequest="44" HeightRequest="44"
                                                    StrokeShape="RoundRectangle 22"
                                                    BackgroundColor="{StaticResource AccentSubtle}"
                                                    StrokeThickness="0"
                                                    Margin="12,0">
                                                <Label Text="{Binding Icon}"
                                                       FontSize="22"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>

                                            <!-- Text -->
                                            <VerticalStackLayout Grid.Column="2"
                                                                  Spacing="3"
                                                                  VerticalOptions="Center">
                                                <Label Text="{Binding Title}"
                                                       FontFamily="DMSansSemiBold"
                                                       FontSize="15"
                                                       TextColor="{StaticResource TextPrimary}"/>
                                                <Label Text="{Binding Message}"
                                                       Style="{StaticResource BodyText}"
                                                       LineBreakMode="WordWrap"
                                                       MaxLines="2"/>
                                                <Label Text="{Binding RelativeTime}"
                                                       Style="{StaticResource CaptionText}"
                                                       Margin="0,2,0,0"/>
                                            </VerticalStackLayout>

                                            <!-- Delete button -->
                                            <Label Grid.Column="3"
                                                   Text="✕"
                                                   FontSize="13"
                                                   TextColor="{StaticResource TextMuted}"
                                                   VerticalOptions="Start"
                                                   Padding="8,0,0,0">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=DeleteNotificationCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Grid>
                                    </Border>

                                    <!-- Unread blue dot indicator -->
                                    <Ellipse Fill="#2563EB"
                                             WidthRequest="8" HeightRequest="8"
                                             HorizontalOptions="End"
                                             VerticalOptions="Start"
                                             Margin="0,-4,-4,0"
                                             IsVisible="{Binding IsRead,
                                                 Converter={StaticResource InverseBoolConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>
