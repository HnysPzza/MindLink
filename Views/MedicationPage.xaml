<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:M1ndLink.Controls"
             xmlns:vm="clr-namespace:M1ndLink.ViewModels"
             xmlns:models="clr-namespace:M1ndLink.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="M1ndLink.Views.MedicationPage"
             x:DataType="vm:MedicationViewModel"
             x:Name="MedPageRoot"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}" />
    </ContentPage.Behaviors>

    <Grid>
        <controls:GradientBackgroundView InputTransparent="True" ZIndex="0"/>

        <Grid ZIndex="1" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Border Grid.Row="0" StrokeThickness="0" Padding="20,52,20,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FEF3C7" Offset="0"/>
                        <GradientStop Color="#00FEF3C7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label Grid.Column="0" Text="←" FontSize="22" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                        <Label Text="Medications" Style="{StaticResource DisplayHeading}"/>
                        <Label Text="Track refills and reminders." Style="{StaticResource CaptionText}"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="+" FontSize="32" TextColor="{StaticResource AccentPrimary}" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowAddMedCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <!-- List -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Medications}" Margin="20,8,20,20">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Medication">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="18" FontFamily="SyneBold" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Dosage}" FontSize="14" FontFamily="JakartaRegular" TextColor="{StaticResource TextMuted}" />
                                    <Label Text="{Binding CurrentPillCount, StringFormat='Pills remaining: {0}'}" FontSize="12" FontFamily="JakartaRegular" TextColor="{StaticResource AccentPrimary}" Margin="0,4,0,0" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Take Dose" Style="{StaticResource PrimaryButton}" HeightRequest="36" Padding="12,0" VerticalOptions="Center"
                                        Clicked="OnTakeDoseClicked" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="40" Spacing="16" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="💊" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="No medications tracked" Style="{StaticResource SectionHeading}" HorizontalOptions="Center"/>
                        <Label Text="Tap + to add your first medication refill reminder." Style="{StaticResource BodyText}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Add Med Popup overlay -->
            <Grid Grid.Row="0" Grid.RowSpan="3" BackgroundColor="#80000000" IsVisible="{Binding IsAddMedVisible}" ZIndex="10">
                <Border Style="{StaticResource CardBorder}" Margin="24" Padding="20" BackgroundColor="{StaticResource CardBackground}" VerticalOptions="Center">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Add Medication" Style="{StaticResource SectionHeading}"/>
                        
                        <Border Style="{StaticResource InputBorder}" Padding="12,0">
                            <Entry Text="{Binding NewMedName}" Placeholder="Medication Name (e.g. Sertraline)" BackgroundColor="Transparent" TextColor="{StaticResource TextPrimary}"/>
                        </Border>
                        
                        <Grid ColumnDefinitions="*,*">
                            <Border Grid.Column="0" Style="{StaticResource InputBorder}" Padding="12,0" Margin="0,0,8,0">
                                <Entry Text="{Binding NewMedDosage}" Placeholder="Dosage (50mg)" BackgroundColor="Transparent" TextColor="{StaticResource TextPrimary}"/>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource InputBorder}" Padding="12,0">
                                <Entry Text="{Binding NewMedCurrentCount, StringFormat='{0}'}" Placeholder="Pill Count" Keyboard="Numeric" BackgroundColor="Transparent" TextColor="{StaticResource TextPrimary}"/>
                            </Border>
                        </Grid>
                        
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Daily Reminder Time" Style="{StaticResource CaptionText}"/>
                            <Border Style="{StaticResource InputBorder}" Padding="12,0">
                                <TimePicker Time="{Binding NewMedReminderTime}" TextColor="{StaticResource TextPrimary}" BackgroundColor="Transparent" Margin="-12,0,0,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">
                            <Button Grid.Column="0" Text="Cancel" BackgroundColor="Transparent" TextColor="{StaticResource TextMuted}" Command="{Binding CancelAddMedCommand}"/>
                            <Button Grid.Column="1" Text="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveMedicationCommand}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
